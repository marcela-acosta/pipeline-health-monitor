# Airflow environment variables — copy this file to .env and adjust as needed.
# The startup script does this automatically on first boot.

# UID that Airflow containers run as. 50000 is the default for the official image.
AIRFLOW_UID=50000

# Initial admin user created on first run (change in production!)
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
